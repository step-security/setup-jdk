{
  "name": "setup-jdk",
  "version": "2.5.1",
  "private": true,
  "description": "Setup JDK action",
  "main": "dist/setup/index.js",
  "scripts": {
    "build": "ncc build -o dist/setup src/setup-jdk.ts && ncc build -o dist/cleanup src/cleanup-java.ts",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/step-security/setup-jdk.git"
  },
  "keywords": [
    "actions",
    "java",
    "openjdk",
    "adoptopenjdk",
    "setup"
  ],
  "author": "step-security",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^2.0.0",
    "@actions/exec": "^2.0.0",
    "@actions/http-client": "^3.0.0",
    "@actions/io": "^3.0.2",
    "@actions/tool-cache": "^3.0.0",
    "axios": "^1.16.0",
    "semver": "^6.1.1",
    "xmlbuilder2": "^2.1.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^24.0.0",
    "@types/semver": "^6.0.0",
    "@vercel/ncc": "^0.38.4",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0",
    "prettier": "^1.19.1",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  }
}
